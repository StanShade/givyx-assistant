# Shared sign-in password. Anyone with this can read the whole operating memory.
OPS_DASHBOARD_PASSWORD=change-me

# HMAC key for the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Changing it signs every existing session out.
OPS_DASHBOARD_SECRET=change-me-to-32-plus-random-bytes

# Absolute path to the PersonalAssistant git checkout the dashboard reads and writes.
# Defaults to the parent directory of the app, which is correct for local dev.
OPS_DATA_DIR=/Users/stan/Code/givyx/PersonalAssistant

# Live plan catalog. Read-only, public, optional — the home view degrades to
# "unavailable" if it cannot be reached.
OPS_PLANS_URL=https://api.givyx.com/plans
